---
// Ambient background: the seven glyph operators scattered at low opacity,
// drifting slowly. Pure CSS — no JS, no canvas. Positions are deterministic
// so the scene doesn't rearrange on every reload.

const operators = [
  { c: '→', x: 8,  y: 12, size: 9.0, delay: 0,   dur: 34 },
  { c: ':', x: 22, y: 78, size: 7.5, delay: 4,   dur: 41 },
  { c: '|', x: 88, y: 22, size: 8.0, delay: 2,   dur: 37 },
  { c: '>', x: 72, y: 88, size: 9.5, delay: 9,   dur: 45 },
  { c: '!', x: 46, y: 6,  size: 6.5, delay: 13,  dur: 29 },
  { c: '=', x: 92, y: 54, size: 8.5, delay: 6,   dur: 39 },
  { c: '(', x: 4,  y: 46, size: 11,  delay: 11,  dur: 48 },
  { c: ')', x: 96, y: 72, size: 11,  delay: 1,   dur: 43 },
  { c: '→', x: 58, y: 32, size: 7.0, delay: 17,  dur: 36 },
  { c: ':', x: 34, y: 58, size: 6.0, delay: 22,  dur: 31 },
  { c: '|', x: 14, y: 92, size: 7.5, delay: 8,   dur: 40 },
  { c: '>', x: 30, y: 24, size: 6.5, delay: 15,  dur: 33 },
  { c: '!', x: 80, y: 8,  size: 7.0, delay: 19,  dur: 38 },
  { c: '=', x: 64, y: 64, size: 7.5, delay: 3,   dur: 42 },
  { c: '→', x: 40, y: 44, size: 5.5, delay: 24,  dur: 35 },
  { c: ':', x: 76, y: 40, size: 5.0, delay: 7,   dur: 30 },
];
---

<div class="glyph-field" aria-hidden="true">
  {operators.map((op) => (
    <span
      class="op"
      style={`--x:${op.x}%; --y:${op.y}%; --size:${op.size}rem; --delay:${op.delay}s; --dur:${op.dur}s;`}
    >{op.c}</span>
  ))}
</div>

<style>
  .glyph-field {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .op {
    position: absolute;
    left: var(--x);
    top: var(--y);
    font-family: var(--ape-font-mono);
    font-size: var(--size);
    font-weight: 300;
    color: var(--ape-amber);
    opacity: 0.055;
    transform: translate(-50%, -50%);
    will-change: transform, opacity;
    animation: drift var(--dur) ease-in-out infinite;
    animation-delay: calc(var(--delay) * -1s);
    user-select: none;
  }

  @keyframes drift {
    0%, 100% {
      transform: translate(-50%, -50%) translate(0, 0) rotate(0deg);
      opacity: 0.04;
    }
    25% {
      transform: translate(-50%, -50%) translate(1.5vw, -1vh) rotate(2deg);
      opacity: 0.08;
    }
    50% {
      transform: translate(-50%, -50%) translate(-1vw, 1.5vh) rotate(-1deg);
      opacity: 0.06;
    }
    75% {
      transform: translate(-50%, -50%) translate(0.8vw, 0.6vh) rotate(1.5deg);
      opacity: 0.09;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .op {
      animation: none;
      opacity: 0.06;
    }
  }
</style>
