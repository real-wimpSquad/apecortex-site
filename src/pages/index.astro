---
import GlyphField from '../components/GlyphField.astro';
import '../styles/tokens.css';
import '../styles/starlight-theme.css';
import '../styles/page-layout.css';
const base = import.meta.env.BASE_URL;
---

<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>APE — Self-hosted AI memory you actually own</title>
    <meta
      name="description"
      content="APE is a self-hosted, air-gappable AI memory layer that runs on your own hardware. Your assistant remembers your work across sessions, models, and vendors — Claude, ChatGPT, any AI tool that supports MCP. Context warming pulls the right memories into the prompt before the AI sees it. No subscription."
    />
    <meta name="keywords" content="AI memory, persistent AI memory, self-hosted AI memory, local AI memory, private AI memory, air-gapped AI, vendor-neutral AI memory, MCP memory server, Claude memory, ChatGPT memory, context warming" />
    <meta property="og:title" content="APE — Self-hosted AI memory you actually own" />
    <meta
      property="og:description"
      content="Persistent, air-gappable AI memory across Claude, ChatGPT, and any MCP client. Install it on your own machine. No subscription."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://apecortex.com" />
    <meta property="og:image" content="https://apecortex.com/og-ape.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="1200" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://apecortex.com/og-ape.jpg" />

    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com https://fonts.googleapis.com; connect-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@300;400;500&family=Instrument+Serif:ital@0;1&display=swap"
    />
  </head>

  <body>
    <GlyphField />

    <header class="topnav">
      <a class="brand" href={base}>
        <span class="brand-mark" aria-hidden="true">→</span>
        <span class="brand-name">APE</span>
      </a>
      <nav>
        <a href={`${base}/technical`}>Technical</a>
        <a href={`${base}/intro`}>Docs</a>
        <a href="https://github.com/real-wimpSquad/ape" rel="noopener">GitHub</a>
      </nav>
    </header>

    <main>
      <!-- ─────────────────────────  HERO  ───────────────────────── -->
      <section class="hero">
        <p class="hero-eyebrow">Self-hosted · Air-gappable · Vendor-neutral</p>
        <h1 class="hero-title">
          Your AI forgets you<br />
          every session.<br />
          <span class="accent">APE remembers.</span>
        </h1>
        <p class="hero-sub">
          Install APE on your own hardware. It pulls the right context into
          every prompt — automatically — and remembers across sessions, models,
          and vendors. Works with Claude, ChatGPT, and any AI tool that supports
          MCP. No cloud account. No subscription. Air-gap it if you want.
        </p>
        <div class="cta-row">
          <a class="cta primary" href="#install">Install in 60s →</a>
          <a class="cta ghost" href="#how">How it works</a>
          <a class="cta ghost" href="https://github.com/real-wimpSquad/ape" rel="noopener">
            GitHub
          </a>
        </div>
      </section>

      <!-- ─────────────────────────  THE PROBLEM  ───────────────────────── -->
      <section class="problem" id="problem">
        <p class="block-eyebrow">The problem</p>
        <h2 class="block-head">AI assistants are powerful — and amnesiac.</h2>
        <ul class="pain-list">
          <li class="pain" data-reveal style="--i:0">
            <span class="pain-mark">01</span>
            <div>
              <h3>It forgets.</h3>
              <p>Every new chat starts from zero. You re-explain your team, your stack, your account, your last conversation. Every. Single. Time.</p>
            </div>
          </li>
          <li class="pain" data-reveal style="--i:1">
            <span class="pain-mark">02</span>
            <div>
              <h3>It isn't yours.</h3>
              <p>The "memory" features baked into Claude and ChatGPT live on their servers, in their account, under their rules. Your context is their asset.</p>
            </div>
          </li>
          <li class="pain" data-reveal style="--i:2">
            <span class="pain-mark">03</span>
            <div>
              <h3>It's locked in.</h3>
              <p>Switch from Claude to ChatGPT — or move your team to a new model next year — and everything your AI learned about you stays behind.</p>
            </div>
          </li>
        </ul>
      </section>

      <!-- ─────────────────────────  WHAT APE DOES  ───────────────────────── -->
      <section class="solution">
        <p class="block-eyebrow">The fix</p>
        <h2 class="block-head">A memory layer that lives on <em>your</em> hardware.</h2>
        <p class="block-lede">
          APE sits between you and your AI tools. Conversations flow through it,
          the important parts get stored on your hardware, and the relevant
          slice gets pulled back into context before the next prompt is sent.
          No re-explaining. No cloud. No subscription.
        </p>

        <div class="benefit-grid">
          <div class="benefit" data-reveal style="--i:0">
            <p class="benefit-tag">Persistent</p>
            <h3>Remembers across sessions, models, and vendors.</h3>
            <p>Pick up where you left off — even after switching from Claude to ChatGPT or upgrading to next year's model. Your memory outlives any single tool.</p>
          </div>
          <div class="benefit" data-reveal style="--i:1">
            <p class="benefit-tag">Yours</p>
            <h3>Lives on your hardware. Air-gap it if you want.</h3>
            <p>Memory never leaves your hardware. Run it fully offline for legal, compliance, or peace-of-mind. Your data doesn't train anyone else's model.</p>
          </div>
          <div class="benefit" data-reveal style="--i:2">
            <p class="benefit-tag">Context warming</p>
            <h3>Pulls the right context before the AI sees the prompt.</h3>
            <p>Before each request leaves your machine, APE attaches the memories that matter for what you're asking. No prompt-engineering, no "remember this."</p>
          </div>
          <div class="benefit" data-reveal style="--i:3">
            <p class="benefit-tag">Yours to keep</p>
            <h3>One install. No subscription. No vendor.</h3>
            <p>You host it, you own it. Nobody bills you monthly for access to your own memory. Updates are opt-in, backups are local, and your data is a single file you can copy.</p>
          </div>
        </div>
      </section>

      <!-- ─────────────────────────  SEE IT  ───────────────────────── -->
      <section class="see">
        <p class="block-eyebrow">See it</p>
        <h2 class="block-head">Three places it earns its keep.</h2>

        <div class="scenarios">
          <article class="scenario" data-reveal style="--i:0">
            <p class="scenario-tag">Sales</p>
            <p class="scenario-title">The Acme account, three weeks later.</p>
            <div class="scenario-said">
              <p class="said-when">Tuesday standup</p>
              <p class="said-body">"Acme deal — Priya in Eng is the decision-maker. Budget approved through Q3. SOC2 timing is their open objection."</p>
            </div>
            <div class="scenario-row">
              <p class="row-tag">Without APE</p>
              <p class="row-body">"Can you remind me where we are with Acme?"</p>
            </div>
            <div class="scenario-row good">
              <p class="row-tag">With APE</p>
              <p class="row-body">"You're calling Priya, the Eng decision-maker. Budget's approved through Q3 — she's still waiting on your SOC2 timeline."</p>
            </div>
          </article>

          <article class="scenario" data-reveal style="--i:1">
            <p class="scenario-tag">Support</p>
            <p class="scenario-title">The customer who keeps coming back.</p>
            <div class="scenario-said">
              <p class="said-when">Last week's ticket</p>
              <p class="said-body">"We're on the Enterprise tier, deployed self-hosted in eu-west-1, integrated with Salesforce."</p>
            </div>
            <div class="scenario-row">
              <p class="row-tag">Without APE</p>
              <p class="row-body">"Tell me your setup again."</p>
            </div>
            <div class="scenario-row good">
              <p class="row-tag">With APE</p>
              <p class="row-body">"Enterprise · self-hosted eu-west-1 · Salesforce. What's broken today?"</p>
            </div>
          </article>

          <article class="scenario" data-reveal style="--i:2">
            <p class="scenario-tag">Internal</p>
            <p class="scenario-title">What did we decide, again?</p>
            <div class="scenario-said">
              <p class="said-when">Q2 planning meeting</p>
              <p class="said-body">"Ship audit-log this quarter. Defer the SSO rewrite. Greenlit a second SRE hire."</p>
            </div>
            <div class="scenario-row">
              <p class="row-tag">Without APE</p>
              <p class="row-body">"What did we decide about SSO?"</p>
            </div>
            <div class="scenario-row good">
              <p class="row-tag">With APE</p>
              <p class="row-body">"From Q2 planning: SSO rewrite deferred, audit-log prioritized, SRE hire approved."</p>
            </div>
          </article>
        </div>
      </section>

      <!-- ─────────────────────────  HOW IT WORKS  ───────────────────────── -->
      <section class="how" id="how">
        <p class="block-eyebrow">How it works</p>
        <h2 class="block-head">Three moving parts. Nothing leaves your hardware.</h2>

        <ol class="steps">
          <li class="step" data-reveal style="--i:0">
            <span class="step-num">01</span>
            <div>
              <h3>APE listens.</h3>
              <p>It sits between your AI tool and the model. Every conversation passes through it on the way in and on the way out.</p>
            </div>
          </li>
          <li class="step" data-reveal style="--i:1">
            <span class="step-num">02</span>
            <div>
              <h3>APE compresses.</h3>
              <p>Each exchange gets translated into a compact memory stored on your hardware — facts, decisions, relationships, and who said what.</p>
            </div>
          </li>
          <li class="step" data-reveal style="--i:2">
            <span class="step-num">03</span>
            <div>
              <h3>APE warms the next prompt.</h3>
              <p>When you start a new conversation, APE pulls the relevant slice of your memory and attaches it to the prompt — before the AI sees a thing.</p>
            </div>
          </li>
        </ol>

        <p class="how-handoff">
          Want the gritty version — the translation language, the graph schema,
          the architecture? <a href={`${base}/technical`}>Read the technical page →</a>
        </p>
      </section>

      <!-- ─────────────────────────  FAQ  ───────────────────────── -->
      <section class="faq" id="faq">
        <p class="block-eyebrow">Frequently asked</p>
        <h2 class="block-head">Common questions, straight answers.</h2>

        <div class="faq-list">
          <details class="faq-item" data-reveal style="--i:0">
            <summary>
              <span class="faq-q">Everyone claims "persistent memory" now. How is APE different?</span>
              <span class="faq-toggle" aria-hidden="true">+</span>
            </summary>
            <div class="faq-a">
              <p>
                The "memory" features built into Claude and ChatGPT live on
                <em>their</em> servers, tied to <em>their</em> account, governed
                by <em>their</em> policies — and they only work inside <em>their</em>
                app. Switch tools and your memory stays behind.
              </p>
              <p>
                APE runs on your hardware. It follows you across Claude,
                ChatGPT, and any AI tool that supports MCP. And it warms
                context into the <strong>prompt itself</strong> — so the memory
                works whether you're using a chat window, a coding tool, or
                calling the API directly. You can read the source, run it
                offline, and walk away with your data any time.
              </p>
            </div>
          </details>

          <details class="faq-item" data-reveal style="--i:1">
            <summary>
              <span class="faq-q">Why APE at all? Why not just keep notes in markdown files?</span>
              <span class="faq-toggle" aria-hidden="true">+</span>
            </summary>
            <div class="faq-a">
              <p>
                A folder of notes can't pull itself into a prompt. You have to
                remember which file to attach, every time. And when the
                notes get long, you blow your context window.
              </p>
              <p>
                APE does the attaching for you: it watches the conversation,
                decides what's worth remembering, compresses it, and serves the
                <em>right slice</em> back when you need it — without you lifting
                a finger. Notes are storage. APE is a working memory that
                knows what's relevant.
              </p>
            </div>
          </details>

          <details class="faq-item" data-reveal style="--i:2">
            <summary>
              <span class="faq-q">What is "air-gapped"? My data is regulated — I can't use APIs.</span>
              <span class="faq-toggle" aria-hidden="true">+</span>
            </summary>
            <div class="faq-a">
              <p>
                Air-gapped means APE runs with <strong>zero outbound network
                traffic</strong>. No calls to Claude, ChatGPT, OpenAI, or any
                other vendor.
              </p>
              <p>
                Point APE at a local model running on your own hardware (LM
                Studio, Ollama, llama.cpp, vLLM) and everything — storage,
                retrieval, translation, the conversation itself — happens
                inside your network. For regulated environments — healthcare,
                finance, defense, legal — this is the difference between "we
                can pilot this" and "we can't even start."
              </p>
            </div>
          </details>

          <details class="faq-item" data-reveal style="--i:3">
            <summary>
              <span class="faq-q">Does it work for teams, or just one person?</span>
              <span class="faq-toggle" aria-hidden="true">+</span>
            </summary>
            <div class="faq-a">
              <p>
                One installation, many users. Each person has their own login
                and their own slice of memory. You can also set up dedicated
                spaces for shared team knowledge — the customer base, your
                product docs, last quarter's decisions, the runbook.
              </p>
              <p>
                APE is a tool you run <em>for</em> your team — not a
                multi-tenant cloud service running for everyone else's team at
                the same time. Your team's memory stays on your team's
                hardware.
              </p>
            </div>
          </details>

          <details class="faq-item" data-reveal style="--i:4">
            <summary>
              <span class="faq-q">What if APE remembers something wrong? Can I see what's stored?</span>
              <span class="faq-toggle" aria-hidden="true">+</span>
            </summary>
            <div class="faq-a">
              <p>
                Yes. Every memory APE has stored is visible in the web UI —
                browse it, search it, edit it, delete it, see who said what
                and when. You're never trusting a black box.
              </p>
              <p>
                If a memory turns out to be wrong or outdated, you can
                down-vote it (which de-ranks it during retrieval) or remove it
                outright. The next time the AI asks the graph, the bad memory
                is gone.
              </p>
            </div>
          </details>

          <details class="faq-item" data-reveal style="--i:5">
            <summary>
              <span class="faq-q">If APE is open source, how does it stay alive?</span>
              <span class="faq-toggle" aria-hidden="true">+</span>
            </summary>
            <div class="faq-a">
              <p>
                Apache 2.0 — installing and running APE is <strong>free,
                forever</strong>, for anyone. The commercial side is support,
                implementation help, team training, and the long-term
                engineering work of keeping the project healthy (so the answer
                to the next question stays "you'll be fine").
              </p>
              <p>
                If you just want to install it and use it, you never have to
                talk to us.
              </p>
            </div>
          </details>

          <details class="faq-item" data-reveal style="--i:6">
            <summary>
              <span class="faq-q">What happens if APE the project goes away?</span>
              <span class="faq-toggle" aria-hidden="true">+</span>
            </summary>
            <div class="faq-a">
              <p>
                Your data is on your hardware, in a single file you can copy.
                The code is open source under Apache 2.0 — fork it, run the
                version you have today forever, or take it in whatever
                direction you want.
              </p>
              <p>
                Nothing about APE depends on us being around. That's the
                point.
              </p>
            </div>
          </details>
        </div>
      </section>

      <!-- ─────────────────────────  INSTALL  ───────────────────────── -->
      <section class="install" id="install">
        <p class="block-eyebrow">Install</p>
        <h2 class="block-head">One clone. One script. Sixty seconds.</h2>
        <p class="block-lede">
          Pull the repo, run the setup script, and APE is up. If you're missing
          anything it needs, the script walks you through installing it. No
          compiling, no config files to babysit — everything else lives in a
          web UI after first boot.
        </p>

        <div class="install-grid">
          <div class="install-block">
            <p class="os-tag">macOS · Linux</p>
            <pre class="install-code"><code>git clone https://github.com/real-wimpSquad/ape
cd ape
bash ape.sh</code></pre>
          </div>
          <div class="install-block">
            <p class="os-tag">Windows</p>
            <pre class="install-code"><code>git clone https://github.com/real-wimpSquad/ape
cd ape
ape.bat</code></pre>
          </div>
        </div>

        <p class="install-after">
          Open <code>http://localhost:8070</code>, paste the one-time setup
          token from the logs, add an API key in the UI, and you're done.
          Point any MCP-capable client at <code>http://localhost:8070/mcp</code>.
        </p>

        <div class="cta-row install-ctas">
          <a class="cta primary" href={`${base}/intro`}>Read the docs →</a>
          <a class="cta ghost" href="https://github.com/real-wimpSquad/ape" rel="noopener">
            Source on GitHub
          </a>
        </div>
      </section>
    </main>

    <!-- ─────────────────────────  FOOTER  ───────────────────────── -->
    <footer class="site-footer">
      <div class="footer-grid">
        <div class="footer-col footer-brand">
          <p class="footer-mark"><span class="mark-arrow">→</span> APE</p>
          <p class="footer-tagline">Agent Persistence Exocortex.</p>
          <p class="footer-stack">Self-hosted · Air-gappable · Vendor-neutral</p>
        </div>

        <div class="footer-col">
          <p class="footer-head">The page</p>
          <ul>
            <li><a href="#problem">The problem</a></li>
            <li><a href="#how">How it works</a></li>
            <li><a href="#faq">FAQ</a></li>
            <li><a href="#install">Install</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <p class="footer-head">Documentation</p>
          <ul>
            <li><a href={`${base}/technical`}>Technical overview</a></li>
            <li><a href={`${base}/intro`}>What is APE?</a></li>
            <li><a href={`${base}/glyph-primer`}>Glyph primer</a></li>
            <li><a href={`${base}/runtime/architecture`}>Runtime architecture</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <p class="footer-head">Source</p>
          <ul>
            <li><a href="https://github.com/real-wimpSquad/ape" rel="noopener">GitHub</a></li>
            <li><a href="https://github.com/real-wimpSquad/ape/issues" rel="noopener">Issues</a></li>
            <li><a href="https://github.com/real-wimpSquad/ape/blob/main/LICENSE" rel="noopener">License</a></li>
          </ul>
        </div>
      </div>

      <div class="footer-rule"></div>
      <p class="footer-copy">
        APE — a self-hosted exocortex.
        Memory, dressed for the occasion.
      </p>
    </footer>

    <style>
      /* Landing-page primary is cool teal — the trust register the page
         lives in. Override --ape-amber tokens so every reference (hero
         accent, eyebrows, CTAs, brand mark, FAQ, footer) picks up cool
         automatically. /technical keeps the editorial amber from
         tokens.css. */
      :root {
        --ape-amber: #4ea9a0;
        --ape-amber-bright: #7ed1c6;
        --ape-amber-dim: #3d6b66;
      }
      :root[data-theme='light'] {
        --ape-amber: #1f5e58;
        --ape-amber-bright: #14463f;
        --ape-amber-dim: #5a8a82;
      }

      /* ────────────────  Hero  ──────────────── */

      .hero {
        padding: 4.5rem 0 6.5rem;
      }
      .hero-eyebrow {
        font-family: var(--ape-font-mono);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        color: var(--ape-amber-dim);
        margin: 0 0 2.25rem;
      }
      .hero-title {
        font-family: var(--ape-font-display);
        font-weight: 400;
        font-size: clamp(2.6rem, 7vw, 5rem);
        line-height: 1.02;
        letter-spacing: -0.018em;
        margin: 0 0 2.25rem;
        color: var(--ape-text);
      }
      .hero-title .accent {
        color: var(--ape-amber);
        font-style: italic;
      }
      .hero-sub {
        font-family: var(--ape-font-prose);
        font-size: 1.18rem;
        line-height: 1.6;
        color: var(--ape-text-muted);
        max-width: 42rem;
        margin: 0 0 2.75rem;
      }

      /* ────────────────  Block headers (shared by problem/solution/see/how/install)  ──────────────── */

      .block-eyebrow {
        font-family: var(--ape-font-mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.28em;
        color: var(--ape-amber);
        margin: 0 0 1.25rem;
      }
      .block-head {
        font-family: var(--ape-font-display);
        font-weight: 400;
        font-size: clamp(1.9rem, 3.6vw, 2.75rem);
        line-height: 1.18;
        letter-spacing: -0.01em;
        color: var(--ape-text);
        margin: 0 0 1.75rem;
        max-width: 38rem;
      }
      .block-head em {
        font-style: italic;
        color: var(--ape-amber);
      }
      .block-lede {
        font-family: var(--ape-font-prose);
        font-size: 1.08rem;
        line-height: 1.65;
        color: var(--ape-text-muted);
        max-width: 42rem;
        margin: 0 0 3rem;
      }

      /* ────────────────  Problem  ──────────────── */

      .pain-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
      }
      @media (min-width: 760px) {
        .pain-list { grid-template-columns: repeat(3, 1fr); }
      }
      .pain {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.85rem;
        align-items: start;
      }
      @media (min-width: 760px) {
        .pain { grid-template-columns: 1fr; gap: 1rem; }
      }
      .pain-mark {
        font-family: var(--ape-font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        color: var(--ape-amber-dim);
        padding-top: 0.15rem;
      }
      .pain h3 {
        font-family: var(--ape-font-display);
        font-weight: 400;
        font-size: 1.45rem;
        line-height: 1.2;
        color: var(--ape-text);
        margin: 0 0 0.45rem;
      }
      .pain p {
        font-family: var(--ape-font-prose);
        font-size: 0.98rem;
        line-height: 1.6;
        color: var(--ape-text-muted);
        margin: 0;
      }

      /* ────────────────  Solution / benefits  ──────────────── */

      .benefit-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
      @media (min-width: 760px) {
        .benefit-grid { grid-template-columns: repeat(2, 1fr); gap: 2rem; }
      }
      .benefit {
        padding: 1.75rem;
        border: 1px solid var(--ape-border);
        border-radius: 6px;
        background: var(--ape-bg-card);
        box-shadow: var(--ape-shadow-card);
      }
      .benefit-tag {
        font-family: var(--ape-font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        color: var(--ape-amber);
        margin: 0 0 0.85rem;
      }
      .benefit h3 {
        font-family: var(--ape-font-display);
        font-weight: 400;
        font-size: 1.4rem;
        line-height: 1.25;
        color: var(--ape-text);
        margin: 0 0 0.75rem;
      }
      .benefit p {
        font-family: var(--ape-font-prose);
        font-size: 0.98rem;
        line-height: 1.6;
        color: var(--ape-text-muted);
        margin: 0;
      }

      /* ────────────────  Scenarios (see it)  ──────────────── */

      .scenarios {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
      @media (min-width: 900px) {
        .scenarios { grid-template-columns: repeat(3, 1fr); }
      }
      .scenario {
        padding: 1.75rem;
        border: 1px solid var(--ape-border);
        border-radius: 6px;
        background: var(--ape-bg-card);
        box-shadow: var(--ape-shadow-card);
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .scenario-tag {
        font-family: var(--ape-font-mono);
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        color: var(--ape-amber);
        margin: 0;
      }
      .scenario-title {
        font-family: var(--ape-font-display);
        font-style: italic;
        font-size: 1.15rem;
        line-height: 1.35;
        color: var(--ape-text);
        margin: 0 0 0.25rem;
      }
      .scenario-said {
        border-left: 2px solid var(--ape-amber-dim);
        padding: 0.15rem 0 0.15rem 0.85rem;
      }
      .said-when {
        font-family: var(--ape-font-mono);
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--ape-text-faint);
        margin: 0 0 0.3rem;
      }
      .said-body {
        font-family: var(--ape-font-prose);
        font-size: 0.95rem;
        line-height: 1.55;
        color: var(--ape-text);
        margin: 0;
        font-style: italic;
      }
      .scenario-row {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.75rem;
        align-items: baseline;
      }
      .row-tag {
        font-family: var(--ape-font-mono);
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--ape-text-faint);
        margin: 0;
        white-space: nowrap;
      }
      .scenario-row.good .row-tag { color: var(--ape-amber); }
      .row-body {
        font-family: var(--ape-font-prose);
        font-size: 0.93rem;
        line-height: 1.5;
        color: var(--ape-text-muted);
        margin: 0;
      }
      .scenario-row.good .row-body { color: var(--ape-text); }

      /* ────────────────  How it works  ──────────────── */

      .how { max-width: 50rem; }
      .steps {
        list-style: none;
        padding: 0;
        margin: 0 0 2.5rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }
      .step {
        display: grid;
        grid-template-columns: 3rem 1fr;
        gap: 1.25rem;
        align-items: baseline;
      }
      .step-num {
        font-family: var(--ape-font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.18em;
        color: var(--ape-amber);
        padding-top: 0.55rem;
      }
      .step h3 {
        font-family: var(--ape-font-display);
        font-weight: 400;
        font-size: clamp(1.4rem, 2vw, 1.7rem);
        line-height: 1.22;
        color: var(--ape-text);
        margin: 0 0 0.5rem;
      }
      .step p {
        font-family: var(--ape-font-prose);
        font-size: 1rem;
        line-height: 1.6;
        color: var(--ape-text-muted);
        margin: 0;
      }
      .how-handoff {
        font-family: var(--ape-font-display);
        font-style: italic;
        font-size: 1.05rem;
        line-height: 1.55;
        color: var(--ape-text-muted);
        margin: 0;
      }
      .how-handoff a {
        border-bottom: 1px solid var(--ape-border-strong);
        transition: color 0.18s ease, border-color 0.18s ease;
      }
      .how-handoff a:hover { border-bottom-color: var(--ape-amber); }

      /* ────────────────  FAQ  ──────────────── */

      .faq { max-width: 52rem; }
      .faq-list {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
      }
      .faq-item {
        border: 1px solid var(--ape-border);
        border-radius: 6px;
        background: var(--ape-bg-card);
        box-shadow: var(--ape-shadow-card);
        overflow: hidden;
      }
      .faq-item summary {
        list-style: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.25rem;
        padding: 1.25rem 1.5rem;
        transition: background 0.18s ease;
      }
      .faq-item summary::-webkit-details-marker { display: none; }
      .faq-item summary:hover { background: var(--ape-bg-raised); }
      .faq-q {
        font-family: var(--ape-font-display);
        font-weight: 400;
        font-size: clamp(1.1rem, 1.6vw, 1.3rem);
        line-height: 1.3;
        color: var(--ape-text);
      }
      .faq-toggle {
        font-family: var(--ape-font-mono);
        font-size: 1.3rem;
        line-height: 1;
        color: var(--ape-amber);
        transition: transform 0.2s ease;
        flex-shrink: 0;
      }
      .faq-item[open] .faq-toggle { transform: rotate(45deg); }
      .faq-a {
        padding: 0 1.5rem 1.5rem;
        border-top: 1px solid var(--ape-border);
        padding-top: 1.25rem;
      }
      .faq-a p {
        font-family: var(--ape-font-prose);
        font-size: 1rem;
        line-height: 1.65;
        color: var(--ape-text-muted);
        margin: 0 0 0.85rem;
      }
      .faq-a p:last-child { margin-bottom: 0; }
      .faq-a strong {
        font-weight: 500;
        color: var(--ape-text);
      }
      .faq-a em {
        font-style: italic;
        color: var(--ape-text);
      }

      /* ────────────────  Install  ──────────────── */

      .install-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.25rem;
        margin: 0 0 1.75rem;
      }
      @media (min-width: 760px) {
        .install-grid { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
      }
      .install-block {
        border: 1px solid var(--ape-border);
        border-radius: 6px;
        background: var(--ape-bg-raised);
        padding: 1.25rem 1.5rem;
      }
      .os-tag {
        font-family: var(--ape-font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        color: var(--ape-amber);
        margin: 0 0 0.75rem;
      }
      .install-code {
        font-family: var(--ape-font-mono);
        font-size: 0.9rem;
        line-height: 1.7;
        color: var(--ape-text);
        background: transparent;
        margin: 0;
        padding: 0;
        overflow-x: auto;
      }
      .install-code code {
        font-family: inherit;
        color: inherit;
        background: transparent;
        padding: 0;
      }
      .install-after {
        font-family: var(--ape-font-prose);
        font-size: 1rem;
        line-height: 1.65;
        color: var(--ape-text-muted);
        max-width: 44rem;
        margin: 0 0 2rem;
      }
      .install-after code {
        font-family: var(--ape-font-mono);
        font-size: 0.92em;
        color: var(--ape-amber);
        background: rgba(212, 161, 74, 0.08);
        padding: 0.05em 0.35em;
        border-radius: 3px;
      }
      :root[data-theme='light'] .install-after code {
        background: rgba(154, 77, 12, 0.08);
      }
      .install-ctas { margin-top: 0.5rem; }
    </style>

    <script is:inline>
      (() => {
        const items = document.querySelectorAll('[data-reveal]');
        if (!items.length) return;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) {
          items.forEach(el => el.classList.add('visible'));
          return;
        }
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              io.unobserve(e.target);
            }
          }
        }, { threshold: 0.18, rootMargin: '0px 0px -40px 0px' });
        items.forEach(el => io.observe(el));
      })();
    </script>
  </body>
</html>
