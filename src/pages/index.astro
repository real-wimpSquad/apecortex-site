---
import { Image } from 'astro:assets';
import apePortrait from '../assets/ape.png';
import GlyphField from '../components/GlyphField.astro';
import GlyphCard from '../components/GlyphCard.astro';
import '../styles/tokens.css';

// Alt taglines parked here for easy swapping:
//   • "Your agents forget everything. APE is what they remember with."
//   • "Give your agents a past. And a future."
//   • "Memory, compressed. Agents, remembered."
//   • "A cortex for the stateless."
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>APE — Agent Persistence Exocortex</title>
    <meta name="description" content="APE is a persistent, compressed memory layer your AI agents actually remember with — across sessions, models, and tasks." />
    <meta property="og:title" content="APE — Agent Persistence Exocortex" />
    <meta property="og:description" content="A persistent, compressed memory layer your AI agents actually remember with." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://apecortex.com" />
    <meta property="og:image" content="https://apecortex.com/og-ape.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="1200" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://apecortex.com/og-ape.jpg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@300;400;500&family=Instrument+Serif:ital@0;1&display=swap"
    />
  </head>

  <body>
    <GlyphField />

    <header class="topnav">
      <a class="brand" href="/">
        <span class="brand-mark" aria-hidden="true">→</span>
        <span class="brand-name">APE</span>
      </a>
      <nav>
        <a href="/intro">Docs</a>
        <a href="https://github.com/real-wimpSquad/ape" rel="noopener">GitHub</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <p class="eyebrow">Agent · Persistence · Exocortex</p>
        <h1>
          Agents without memory<br />
          are <span class="strike">interns</span>.<br />
          <span class="accent">APE gives them a career.</span>
        </h1>
        <p class="sub">
          A persistent, compressed memory layer your AI agents actually remember with —
          across sessions, models, and vendors.
        </p>
        <div class="cta-row">
          <a class="cta primary" href="/intro">How it works →</a>
          <a class="cta ghost" href="https://github.com/real-wimpSquad/ape" rel="noopener">
            Try APE yourself →
          </a>
        </div>
      </section>

      <section class="what">
        <figure class="portrait">
          <Image
            src={apePortrait}
            alt="A distinguished chimpanzee in a crimson velvet smoking jacket, reading by a fireplace in a leather-bound library. An APE Exocortex mug sits beside an open notebook showing a hand-drawn L1-L2-L3 tiered memory diagram."
            widths={[480, 720, 960, 1254]}
            sizes="(min-width: 900px) 42vw, 90vw"
            loading="eager"
            class="portrait-img"
          />
          <figcaption>The velvet smoking jacket is optional. The memory is not.</figcaption>
        </figure>

        <div class="what-prose">
          <p class="what-eyebrow">— What's actually going on</p>
          <p class="what-lead">
            APE sits quietly behind your agents. It watches what happens — conversations,
            decisions, discoveries — and translates it into <em>glyph</em>, a dense
            operator notation.
          </p>
          <p class="what-body">
            Glyph lives in a graph. The next time an agent needs context, it asks the
            graph, not its own forgetful model. Your agents stop starting from scratch.
          </p>
        </div>
      </section>

      <section class="cards-section">
        <div class="cards-head">
          <h2>Prose in. Glyph out. Prose again if you want it.</h2>
          <p class="cards-sub">
            The operator set is open. Glyph reaches for the most precise symbol
            — <code>→</code> flow, <code>¬</code> negation, <code>∧</code> joint
            requirement, <code>⊂</code> containment, <code>∃</code> existence,
            <code>≡</code> equivalence — borrowing from math and logic, coining
            new ones when nothing fits. Every fact survives; only the representation changes.
          </p>
        </div>

        <div class="cards">
          <GlyphCard
            eyebrow="Meeting note"
            prose="In Tuesday's standup, Priya flagged the auth bug — it's P0, blocks launch, and unblocking it needs both security sign-off and a QA rerun. Hotfix by Friday; rollback if it slips."
            glyph={`(day:Tue_standup)Priya→flagged:auth_bug=P0>blocks:launch
unblock→[security_signoff∧QA_rerun]
plan:hotfix→Friday|(slip→rollback)`}
            back="Tuesday standup — Priya flagged the auth bug (P0, blocks launch); unblocking needs both security sign-off and QA rerun; hotfix Friday, rollback if it slips."
          />
          <GlyphCard
            eyebrow="Bug report"
            prose="The app crashes on startup after the 2.4 update. Affects every iPhone older than the 12. Android and iPad are unaffected. Crash rate jumped from 0.1% to 8% overnight."
            glyph={`crash→startup|trigger:v2.4_update
scope:iPhone(pre_12)|¬scope:[Android|iPad]
crash_rate:0.1%..8%(overnight)`}
            back="Startup crash after v2.4; affects every pre-12 iPhone; Android and iPad unaffected; crash rate jumped 0.1% → 8% overnight."
          />
          <GlyphCard
            eyebrow="Vet visit"
            prose="Took Mia (our Shiba) to the vet this morning. Low-grade ear infection — same strain as last spring, nothing serious. Drops twice daily for a week; if symptoms persist, recheck."
            glyph={`(date:today_AM)Mia(Shiba)→vet
dx:ear_infection(low_grade)≡last_spring_strain|¬serious
tx:drops→2x_daily_7d|(symptoms→persist>recheck)`}
            back="Vet with Mia (our Shiba), this morning — low-grade ear infection, equivalent to last spring's strain, not serious; drops twice daily for a week; recheck if symptoms persist."
          />
        </div>
      </section>

      <section class="why-editorial">
        <p class="why-eyebrow">— Why it matters</p>
        <ol class="statements">
          <li class="statement" data-reveal style="--i:0">
            <span class="marker">01</span>
            <p>
              <span class="key">Dense.</span>
              <em>Glyph is a fraction the size of prose. Your context window goes further.</em>
            </p>
          </li>
          <li class="statement" data-reveal style="--i:1">
            <span class="marker">02</span>
            <p>
              <span class="key">Durable.</span>
              <em>Memories outlive the session, the model, the vendor.</em>
            </p>
          </li>
          <li class="statement" data-reveal style="--i:2">
            <span class="marker">03</span>
            <p>
              <span class="key">Queryable.</span>
              <em>Graph-native retrieval. No fuzzy-search roulette.</em>
            </p>
          </li>
          <li class="statement" data-reveal style="--i:3">
            <span class="marker">04</span>
            <p>
              <span class="key">Yours.</span>
              <em>Runs on your own hardware. No one else holds your agent's mind.</em>
            </p>
          </li>
          <li class="statement" data-reveal style="--i:4">
            <span class="marker">05</span>
            <p>
              <span class="key">Your data is your data.</span>
              <em>It stays on your machine. It doesn't train someone else's model.</em>
            </p>
          </li>
        </ol>
      </section>

      <section class="ship-manifest">
        <h2 class="terminal-head">
          <span class="prompt">$</span><span class="sp"> </span><span class="cmd">ape ship</span><span class="sp"> </span><span class="flag">--list</span><span class="caret">_</span>
        </h2>

        <dl class="manifest">
          <div class="row" data-reveal style="--i:0">
            <dt>--airgap-or-api</dt>
            <dd>run local with your own models, or plug into <span class="value">Claude</span>, <span class="value">ChatGPT</span>, or <span class="value">Grok</span> <span class="note">// yes, really</span></dd>
          </div>
          <div class="row" data-reveal style="--i:1">
            <dt>--no-build</dt>
            <dd>prebuilt images — you never touch a compiler</dd>
          </div>
          <div class="row" data-reveal style="--i:2">
            <dt>--install-time</dt>
            <dd><span class="value">≈ 60s</span> — one command, one config file, one cup of coffee</dd>
          </div>
          <div class="row" data-reveal style="--i:3">
            <dt>--subscriptions</dt>
            <dd><span class="value">none</span> — install it, keep it. nobody bills you monthly for your own memories</dd>
          </div>
          <div class="row" data-reveal style="--i:4">
            <dt>--mcp-native</dt>
            <dd>Claude Code, Claude Desktop, or any MCP-capable client you build</dd>
          </div>
          <div class="row" data-reveal style="--i:5">
            <dt>--vendor-agnostic</dt>
            <dd>swap providers without migrating memories. the cortex outlives the model</dd>
          </div>
          <div class="row" data-reveal style="--i:6">
            <dt>--ops-surface</dt>
            <dd>one service, one store, no sidecars</dd>
          </div>
          <div class="row wink" data-reveal style="--i:7">
            <dt>--jawline</dt>
            <dd><span class="value">incredible</span> <span class="note">// not a feature, strictly speaking. still true.</span></dd>
          </div>
        </dl>
      </section>

      <section class="tech">
        <p class="tech-line">
          Rust · SQLite · Qdrant | MCP · APEChat | enterprise · homelab
        </p>
      </section>
    </main>

    <footer>
      <p>
        APE — Agent Persistence Exocortex ·
        <a href="/intro">Docs</a> ·
        <a href="https://github.com/real-wimpSquad/ape" rel="noopener">GitHub</a>
      </p>
    </footer>

    <style is:global>
      html, body {
        background: var(--ape-bg);
        color: var(--ape-text);
        margin: 0;
        padding: 0;
        font-family: var(--ape-font-prose);
        -webkit-font-smoothing: antialiased;
      }
      ::selection {
        background: var(--ape-amber);
        color: var(--ape-bg);
      }
      a { color: var(--ape-amber); text-decoration: none; }
      a:hover { color: var(--ape-amber-bright); }
    </style>

    <style>
      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .topnav {
        position: relative;
        z-index: 2;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem clamp(1.25rem, 5vw, 3rem);
        max-width: 68rem;
        margin: 0 auto;
        width: 100%;
        box-sizing: border-box;
      }
      .brand {
        display: inline-flex;
        align-items: baseline;
        gap: 0.45rem;
        font-family: var(--ape-font-mono);
        font-weight: 500;
        font-size: 1rem;
        color: var(--ape-text);
        letter-spacing: 0.03em;
      }
      .brand-mark { color: var(--ape-amber); font-size: 1.1em; }
      .topnav nav { display: flex; gap: 1.75rem; }
      .topnav nav a {
        font-family: var(--ape-font-mono);
        font-size: 0.85rem;
        color: var(--ape-text-muted);
        letter-spacing: 0.04em;
      }
      .topnav nav a:hover { color: var(--ape-amber); }

      main {
        position: relative;
        z-index: 1;
        flex: 1;
        max-width: 68rem;
        margin: 0 auto;
        padding: 0 clamp(1.25rem, 5vw, 3rem);
        width: 100%;
        box-sizing: border-box;
      }

      section { padding: 4.5rem 0; }
      section + section { border-top: 1px solid var(--ape-border); }

      .hero { padding-top: 5rem; padding-bottom: 5.5rem; }
      .eyebrow {
        font-family: var(--ape-font-mono);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.28em;
        color: var(--ape-amber-dim);
        margin: 0 0 1.75rem;
      }
      h1 {
        font-family: var(--ape-font-prose);
        font-weight: 700;
        font-size: clamp(2.5rem, 6vw, 4.25rem);
        line-height: 1.08;
        letter-spacing: -0.02em;
        margin: 0 0 1.75rem;
        color: var(--ape-text);
      }
      h1 .strike {
        position: relative;
        color: var(--ape-text-muted);
        font-style: italic;
        font-weight: 500;
      }
      h1 .strike::after {
        content: '';
        position: absolute;
        left: -2%;
        right: -2%;
        top: 58%;
        height: 2px;
        background: var(--ape-amber-dim);
        transform: rotate(-2deg);
      }
      h1 .accent { color: var(--ape-amber); }

      .sub {
        font-size: 1.2rem;
        line-height: 1.55;
        color: var(--ape-text-muted);
        max-width: 36rem;
        margin: 0 0 2.25rem;
      }

      .cta-row { display: flex; gap: 1rem; flex-wrap: wrap; }
      .cta {
        font-family: var(--ape-font-mono);
        font-size: 0.9rem;
        letter-spacing: 0.04em;
        padding: 0.85rem 1.35rem;
        border-radius: 4px;
        transition: background 0.18s ease, border-color 0.18s ease, color 0.18s ease;
      }
      .cta.primary {
        background: var(--ape-amber);
        color: var(--ape-bg);
        border: 1px solid var(--ape-amber);
      }
      .cta.primary:hover {
        background: var(--ape-amber-bright);
        border-color: var(--ape-amber-bright);
        color: var(--ape-bg);
      }
      .cta.ghost {
        background: transparent;
        color: var(--ape-text);
        border: 1px solid var(--ape-border-strong);
      }
      .cta.ghost:hover {
        border-color: var(--ape-amber);
        color: var(--ape-amber);
      }

      h2 {
        font-family: var(--ape-font-prose);
        font-weight: 600;
        font-size: clamp(1.5rem, 3vw, 2rem);
        letter-spacing: -0.01em;
        margin: 0 0 1.5rem;
        color: var(--ape-text);
      }

      /* ───────── What's actually going on — editorial portrait ───────── */

      .what {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2.5rem;
        padding: 5.5rem 0 5rem;
        align-items: start;
      }
      @media (min-width: 900px) {
        .what {
          grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
          gap: 3.5rem;
        }
      }

      .portrait {
        margin: 0;
        padding: 0;
        position: relative;
      }
      .portrait-img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 4px;
        border: 1px solid var(--ape-border);
        box-shadow:
          0 20px 40px -20px rgba(0, 0, 0, 0.55),
          0 4px 12px -4px rgba(0, 0, 0, 0.4);
      }
      .portrait figcaption {
        margin-top: 1rem;
        font-family: var(--ape-font-display);
        font-style: italic;
        font-size: 1rem;
        line-height: 1.45;
        color: var(--ape-text-muted);
        padding-left: 1rem;
        border-left: 1px solid var(--ape-border);
        max-width: 28rem;
      }

      .what-prose {
        padding-top: 0.5rem;
      }
      .what-eyebrow {
        font-family: var(--ape-font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        color: var(--ape-amber-dim);
        margin: 0 0 1.75rem;
      }
      .what-lead {
        margin: 0 0 1.25rem;
        font-family: var(--ape-font-display);
        font-weight: 400;
        font-size: clamp(1.4rem, 2.1vw, 1.75rem);
        line-height: 1.35;
        letter-spacing: -0.005em;
        color: var(--ape-text);
      }
      .what-body {
        margin: 0;
        font-family: var(--ape-font-prose);
        font-size: 1.05rem;
        line-height: 1.65;
        color: var(--ape-text-muted);
      }
      .what em {
        color: var(--ape-amber);
        font-style: normal;
        font-family: var(--ape-font-mono);
        font-size: 0.9em;
      }

      .cards-head { margin-bottom: 2.5rem; }
      .cards-sub {
        color: var(--ape-text-muted);
        font-size: 1rem;
        line-height: 1.6;
        max-width: 52rem;
        margin: 0;
      }
      .cards-sub code {
        font-family: var(--ape-font-mono);
        color: var(--ape-amber);
        background: rgba(212, 161, 74, 0.08);
        padding: 0.05em 0.3em;
        border-radius: 3px;
        font-size: 0.95em;
      }

      .cards {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.25rem;
      }
      @media (min-width: 900px) {
        .cards { grid-template-columns: repeat(3, 1fr); }
      }

      /* ───────────── Why it matters — editorial manifesto ───────────── */

      .why-editorial {
        padding: 6rem 0 6.5rem;
        max-width: 44rem;
        margin-left: 0;   /* left-anchored — asymmetric against surrounding full-width sections */
      }
      .why-eyebrow {
        font-family: var(--ape-font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        color: var(--ape-amber-dim);
        margin: 0 0 3rem;
      }
      .statements {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 2.25rem;
      }
      .statement {
        display: grid;
        grid-template-columns: 2.5rem 1fr;
        gap: 1.4rem;
        align-items: baseline;
        opacity: 0;
        transform: translateY(14px);
        transition:
          opacity 700ms cubic-bezier(.2,.8,.2,1),
          transform 700ms cubic-bezier(.2,.8,.2,1);
        transition-delay: calc(var(--i) * 95ms);
      }
      .statement.visible {
        opacity: 1;
        transform: translateY(0);
      }
      .statement .marker {
        font-family: var(--ape-font-mono);
        font-size: 0.68rem;
        letter-spacing: 0.18em;
        color: var(--ape-amber-dim);
        padding-top: 0.5rem;
      }
      .statement p {
        margin: 0;
        font-family: var(--ape-font-display);
        font-weight: 400;
        font-size: clamp(1.4rem, 2.1vw, 1.85rem);
        line-height: 1.32;
        letter-spacing: -0.005em;
        color: var(--ape-text);
      }
      .statement .key {
        font-style: normal;
        color: var(--ape-amber);
        margin-right: 0.35rem;
      }
      .statement em {
        font-style: italic;
      }

      /* ───────────── How it ships — terminal manifest ───────────── */

      .ship-manifest {
        padding: 5rem 0 7rem;
      }
      .terminal-head {
        font-family: var(--ape-font-mono);
        font-weight: 400;
        font-size: 0.95rem;
        letter-spacing: 0.01em;
        color: var(--ape-text);
        margin: 0 0 2.75rem;
        display: inline-flex;
        align-items: baseline;
      }
      .terminal-head .prompt { color: var(--ape-amber); }
      .terminal-head .sp { white-space: pre; }
      .terminal-head .cmd { color: var(--ape-text); }
      .terminal-head .flag { color: var(--ape-amber); }
      .terminal-head .caret {
        color: var(--ape-amber);
        margin-left: 0.25ch;
        animation: ape-blink 1.1s step-end infinite;
      }
      @keyframes ape-blink {
        0%, 50%  { opacity: 1; }
        51%, 100% { opacity: 0; }
      }

      .manifest {
        margin: 0;
        padding: 0.5rem 0 0.5rem 1.5rem;
        border-left: 1px solid var(--ape-border);
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
      }
      .manifest .row {
        display: grid;
        grid-template-columns: 20ch 1fr;
        column-gap: 1.75rem;
        align-items: baseline;
        font-family: var(--ape-font-mono);
        font-size: 0.92rem;
        line-height: 1.6;
        opacity: 0;
        transform: translateX(-8px);
        transition:
          opacity 500ms ease-out,
          transform 500ms ease-out;
        transition-delay: calc(var(--i) * 60ms);
      }
      .manifest .row.visible {
        opacity: 1;
        transform: translateX(0);
      }
      .manifest dt {
        color: var(--ape-amber);
        font-weight: 400;
        letter-spacing: 0.01em;
      }
      .manifest dd {
        margin: 0;
        color: var(--ape-text-muted);
      }
      .manifest .value {
        color: var(--ape-amber-bright);
      }
      .manifest .note {
        color: var(--ape-text-faint);
        margin-left: 0.4ch;
      }

      @media (max-width: 720px) {
        .manifest { padding-left: 1rem; }
        .manifest .row {
          grid-template-columns: 1fr;
          column-gap: 0;
          row-gap: 0.1rem;
        }
        .manifest dt { padding-bottom: 0.1rem; }
      }

      @media (prefers-reduced-motion: reduce) {
        .statement, .manifest .row {
          opacity: 1;
          transform: none;
          transition: none;
        }
        .terminal-head .caret { animation: none; }
      }

      .tech { padding: 3rem 0 4rem; }
      .tech-line {
        font-family: var(--ape-font-mono);
        font-size: 0.88rem;
        color: var(--ape-text-faint);
        letter-spacing: 0.04em;
        line-height: 1.7;
        margin: 0;
      }

      footer {
        position: relative;
        z-index: 1;
        border-top: 1px solid var(--ape-border);
        padding: 1.75rem clamp(1.25rem, 5vw, 3rem);
        max-width: 68rem;
        margin: 0 auto;
        width: 100%;
        box-sizing: border-box;
        text-align: center;
      }
      footer p {
        font-family: var(--ape-font-mono);
        font-size: 0.78rem;
        color: var(--ape-text-faint);
        letter-spacing: 0.04em;
        margin: 0;
      }
      footer a { color: var(--ape-text-muted); }
      footer a:hover { color: var(--ape-amber); }
    </style>

    <script is:inline>
      (() => {
        const items = document.querySelectorAll('[data-reveal]');
        if (!items.length) return;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) {
          items.forEach(el => el.classList.add('visible'));
          return;
        }
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              io.unobserve(e.target);
            }
          }
        }, { threshold: 0.18, rootMargin: '0px 0px -40px 0px' });
        items.forEach(el => io.observe(el));
      })();
    </script>
  </body>
</html>
