---
import GlyphField from '../components/GlyphField.astro';
import GlyphCard from '../components/GlyphCard.astro';
import '../styles/tokens.css';
import '../styles/starlight-theme.css';
const base = import.meta.env.BASE_URL;
---

<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <!-- Theme synchronization script (matches Starlight behavior) -->
    <script is:inline>
      (() => {
        const html = document.documentElement;
        const stored = localStorage.getItem('starlight-theme') ||
          (document.cookie.match(/starlight-theme=([^;]+)/) || [])[1];
        if (stored) {
          html.setAttribute('data-theme', stored);
        } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          html.setAttribute('data-theme', 'light');
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>APE — Agent Persistence Exocortex</title>
    <meta
      name="description"
      content="A persistent, compressed memory layer for AI agents — across sessions, models, and vendors. Self-hosted. Translation-based. Yours."
    />
    <meta property="og:title" content="APE — Agent Persistence Exocortex" />
    <meta
      property="og:description"
      content="A persistent, compressed memory layer for AI agents — across sessions, models, and vendors."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://apecortex.com" />
    <meta property="og:image" content="https://apecortex.com/og-ape.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="1200" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://apecortex.com/og-ape.jpg" />

    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com https://fonts.googleapis.com; connect-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@300;400;500&family=Instrument+Serif:ital@0;1&display=swap"
    />
  </head>

  <body>
    <GlyphField />

    <header class="topnav">
      <a class="brand" href={base}>
        <span class="brand-mark" aria-hidden="true">→</span>
        <span class="brand-name">APE</span>
      </a>
      <nav>
        <a href={`${base}/intro`}>Docs</a>
        <a href="https://github.com/real-wimpSquad/ape" rel="noopener">GitHub</a>
      </nav>
    </header>

    <main>
      <!-- ─────────────────────────  HERO  ───────────────────────── -->
      <section class="hero">
        <p class="hero-eyebrow">Agent · Persistence · Exocortex</p>
        <h1 class="hero-title">
          A cortex<br />
          for the<br />
          <span class="accent">stateless.</span>
        </h1>
        <p class="hero-sub">
          Stateless agents forget. APE remembers — a self-hosted layer that
          translates what passes through, stores it as a graph, and outlives
          the session, the model, and the vendor. Yours.
        </p>
        <div class="cta-row">
          <a class="cta primary" href={`${base}/intro`}>Read the docs →</a>
          <a class="cta ghost" href="https://github.com/real-wimpSquad/ape" rel="noopener">
            Source on GitHub
          </a>
        </div>
      </section>

      <!-- ─────────────────────────  §I  THE SHAPE  ───────────────────────── -->
      <section class="essay" data-reveal style="--i:0">
        <p class="section-eyebrow">
          <span class="numeral">I.</span><span class="rule"></span><span class="label">The shape</span>
        </p>
        <p class="lede">
          <span class="dropcap">A</span>PE is the
          <strong>Agent Persistence Exocortex</strong> — a memory layer that sits
          beside your agents and remembers for them. It watches what passes
          through — conversations, decisions, discoveries — and translates the
          record into a dense operator notation called
          <em>glyph</em>. The result lives in a graph, not a flat log. The next
          time an agent needs context, it asks the graph. Your agents stop
          starting from scratch.
        </p>
        <p class="aside">
          <em>
            There is, of course, the matter of the name —
            <a href={`${base}/origin`}>a longer story</a>.
          </em>
        </p>
      </section>

      <!-- ─────────────────────────  §II  THE TRANSLATION  ───────────────────────── -->
      <section class="translation">
        <p class="section-eyebrow">
          <span class="numeral">II.</span><span class="rule"></span><span class="label">The translation</span>
        </p>

        <div class="big-translation" data-reveal style="--i:0">
          <div class="big-side big-prose">
            <p class="side-tag">prose in</p>
            <p class="side-text">
              On Tuesday's standup, Priya flagged the auth bug — it's a P0 that
              blocks launch, and unblocking it needs both security sign-off and a
              QA rerun. Hotfix by Friday; rollback if it slips.
            </p>
          </div>

          <div class="big-divider" aria-hidden="true">
            <span class="big-arrow">→</span>
          </div>

          <div class="big-side big-glyph">
            <p class="side-tag">glyph</p>
            <code class="side-text mono">{`(day:Tue_standup)Priya⪽auth_bug{priority:P0}⊣launch
[security_signoff∧QA_rerun]⇒auth_bug⊖
hotfix{deadline:Friday}|hotfix∌deadline⇒rollback`}</code>
          </div>
        </div>

        <p class="translation-blurb">
          One rule: <strong>nouns are nucleoids, everything else is an
          operator.</strong> Entities sit on the page; the relations between
          them are symbols — <code>→</code> causes, <code>⊣</code> blocks,
          <code>∧</code> joint requirement, <code>∈</code> belongs to,
          <code>≡</code> equivalent, <code>⊕</code> create, <code>⊖</code>
          destroy. The alphabet is closed; when a source claim falls outside
          it, the translator surfaces the gap as <code>MISSING</code> rather
          than coining its way around it. Every fact survives; only the
          representation changes.
        </p>

        <p class="translation-more">— And in other shapes:</p>

        <div class="cards">
          <GlyphCard
            eyebrow="Bug report"
            prose="The app crashes on startup after the 2.4 update. Affects every iPhone older than the 12. Android and iPad are unaffected. Crash rate jumped from 0.1% to 8% overnight."
            glyph={`v2.4_update→crash@startup
crash→[⊚iPhone(pre_12)|∌[Android|iPad]]
crash_rate{range:0.1%..8%}@overnight`}
            back="Startup crash after v2.4; affects every pre-12 iPhone; Android and iPad unaffected; crash rate jumped 0.1% → 8% overnight."
          />
          <GlyphCard
            eyebrow="Vet visit"
            prose="Took Mia (our Shiba) to the vet this morning. Low-grade ear infection — same strain as last spring, nothing serious. Drops twice daily for a week; if symptoms persist, recheck."
            glyph={`(date:today_AM)Mia(Shiba)@vet
ear_infection(low_grade){severity:¬serious}≡last_spring_strain
drops{freq:2x_daily|dur:7d}
symptoms(persistent)⇒recheck`}
            back="Vet with Mia (our Shiba), this morning — low-grade ear infection, equivalent to last spring's strain, not serious; drops twice daily for a week; recheck if symptoms persist."
          />
          <GlyphCard
            eyebrow="Travel note"
            prose="Booked the Lisbon trip for the first week of October. Direct flight outbound, one stop in Madrid coming back. Hotel in Alfama; rail day-trip to Sintra mid-week if the weather holds."
            glyph={`Lisbon_trip{date:Oct_W1|hotel:Alfama}
outbound_flight{stops:0}|return_flight{stops:1|via:Madrid}
weather_holds⇒rail_daytrip→Sintra@mid_week`}
            back="Lisbon, first week of October — direct out, one stop via Madrid back; staying in Alfama, day-trip by rail to Sintra mid-week if weather holds."
          />
        </div>
      </section>

      <!-- ─────────────────────────  §III  WHY IT MATTERS  ───────────────────────── -->
      <section class="why">
        <p class="section-eyebrow">
          <span class="numeral">III.</span><span class="rule"></span><span class="label">Why it matters</span>
        </p>
        <ol class="statements">
          <li class="statement" data-reveal style="--i:0">
            <span class="marker">01</span>
            <p>
              <span class="key">Dense.</span>
              <em>Glyph is a fraction the size of prose. Your context window goes further.</em>
            </p>
          </li>
          <li class="statement" data-reveal style="--i:1">
            <span class="marker">02</span>
            <p>
              <span class="key">Durable.</span>
              <em>Memories outlive the session, the model, the vendor.</em>
            </p>
          </li>
          <li class="statement" data-reveal style="--i:2">
            <span class="marker">03</span>
            <p>
              <span class="key">Queryable.</span>
              <em>Graph-native retrieval. No fuzzy-search roulette.</em>
            </p>
          </li>
          <li class="statement" data-reveal style="--i:3">
            <span class="marker">04</span>
            <p>
              <span class="key">Yours.</span>
              <em>Runs on your own hardware. Your data stays on your machine — and doesn't train anyone else's model.</em>
            </p>
          </li>
        </ol>
      </section>

      <!-- ─────────────────────────  §IV  HOW IT SHIPS  ───────────────────────── -->
      <section class="ship">
        <p class="section-eyebrow">
          <span class="numeral">IV.</span><span class="rule"></span><span class="label">How it ships</span>
        </p>

        <h2 class="terminal-head">
          <span class="prompt">$</span><span class="sp"> </span><span class="cmd">ape ship</span><span class="sp"> </span><span class="flag">--list</span><span class="caret">_</span>
        </h2>

        <dl class="manifest">
          <div class="row" data-reveal style="--i:0">
            <dt>--airgap-or-api</dt>
            <dd>run fully airgapped locally, or plug in <span class="value">Claude</span>, <span class="value">ChatGPT</span>, or <span class="value">Grok</span></dd>
          </div>
          <div class="row" data-reveal style="--i:1">
            <dt>--no-build</dt>
            <dd>prebuilt images — you never touch a compiler</dd>
          </div>
          <div class="row" data-reveal style="--i:2">
            <dt>--install-time</dt>
            <dd><span class="value">≈ 60s</span> — one command and you are functional. Full GUI config for Enterprise needs</dd>
          </div>
          <div class="row" data-reveal style="--i:3">
            <dt>--subscriptions</dt>
            <dd><span class="value">none</span> — install it, keep it. nobody bills you monthly for your own memories</dd>
          </div>
          <div class="row" data-reveal style="--i:4">
            <dt>--mcp-native</dt>
            <dd>Claude Code, ChatGPT, LM Studio. Any MCP-capable client</dd>
          </div>
          <div class="row" data-reveal style="--i:5">
            <dt>--vendor-agnostic</dt>
            <dd>swap providers and model families without migrating memories. the cortex outlives the model</dd>
          </div>
          <div class="row" data-reveal style="--i:6">
            <dt>--ops-surface</dt>
            <dd>one service, one store, no sidecars</dd>
          </div>
        </dl>
      </section>
    </main>

    <!-- ─────────────────────────  FOOTER  ───────────────────────── -->
    <footer class="site-footer">
      <div class="footer-grid">
        <div class="footer-col footer-brand">
          <p class="footer-mark"><span class="mark-arrow">→</span> APE</p>
          <p class="footer-tagline">Agent Persistence Exocortex.</p>
          <p class="footer-stack">Rust · SQLite · Qdrant · MCP</p>
        </div>

        <div class="footer-col">
          <p class="footer-head">Documentation</p>
          <ul>
            <li><a href={`${base}/intro`}>What is APE?</a></li>
            <li><a href={`${base}/glyph-primer`}>Glyph primer</a></li>
            <li><a href={`${base}/runtime/architecture`}>Runtime architecture</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <p class="footer-head">Source</p>
          <ul>
            <li><a href="https://github.com/real-wimpSquad/ape" rel="noopener">GitHub</a></li>
            <li><a href="https://github.com/real-wimpSquad/ape/issues" rel="noopener">Issues</a></li>
            <li><a href="https://github.com/real-wimpSquad/ape/blob/main/LICENSE" rel="noopener">License</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <p class="footer-head">Apocrypha</p>
          <ul>
            <li><a href={`${base}/origin`}>Origin</a></li>
          </ul>
        </div>
      </div>

      <div class="footer-rule"></div>
      <p class="footer-copy">
        APE — a self-hosted exocortex.
        Memory, dressed for the occasion.
      </p>
    </footer>

    <style is:global>
      html, body {
        background: var(--ape-bg);
        color: var(--ape-text);
        margin: 0;
        padding: 0;
        font-family: var(--ape-font-prose);
        -webkit-font-smoothing: antialiased;
      }
      ::selection {
        background: var(--ape-amber);
        color: var(--ape-bg);
      }
      a { color: var(--ape-amber); text-decoration: none; }
      a:hover { color: var(--ape-amber-bright); }
    </style>

    <style>
      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* ────────────────  Top nav  ──────────────── */

      .topnav {
        position: relative;
        z-index: 2;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.75rem clamp(1.25rem, 5vw, 3rem);
        max-width: 70rem;
        margin: 0 auto;
        width: 100%;
        box-sizing: border-box;
      }
      .brand {
        display: inline-flex;
        align-items: baseline;
        gap: 0.45rem;
        font-family: var(--ape-font-mono);
        font-weight: 500;
        font-size: 1rem;
        color: var(--ape-text);
        letter-spacing: 0.03em;
      }
      .brand-mark { color: var(--ape-amber); font-size: 1.1em; }
      .topnav nav { display: flex; gap: 1.75rem; }
      .topnav nav a {
        font-family: var(--ape-font-mono);
        font-size: 0.85rem;
        color: var(--ape-text-muted);
        letter-spacing: 0.04em;
      }
      .topnav nav a:hover { color: var(--ape-amber); }

      /* ────────────────  Layout  ──────────────── */

      main {
        position: relative;
        z-index: 1;
        flex: 1;
        max-width: 70rem;
        margin: 0 auto;
        padding: 0 clamp(1.25rem, 5vw, 3rem);
        width: 100%;
        box-sizing: border-box;
      }

      /* Single rhythm: 6.5rem of breath between sections, plus a hairline. */
      section {
        padding: 6.5rem 0;
        position: relative;
      }
      section + section {
        border-top: 1px solid var(--ape-border);
      }

      /* Standardized section eyebrow — Roman numeral · rule · uppercase label */
      .section-eyebrow {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 0 0 3rem;
        font-family: var(--ape-font-mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.28em;
        color: var(--ape-amber-dim);
      }
      .section-eyebrow .numeral {
        font-family: var(--ape-font-display);
        font-style: italic;
        font-size: 1.15rem;
        text-transform: none;
        letter-spacing: 0;
        color: var(--ape-amber);
        line-height: 1;
        padding-top: 0.05em;
      }
      .section-eyebrow .rule {
        flex: 0 0 3rem;
        height: 1px;
        background: var(--ape-amber-dim);
        opacity: 0.55;
      }
      .section-eyebrow .label {
        color: var(--ape-amber-dim);
      }

      /* ────────────────  Hero  ──────────────── */

      .hero {
        padding: 4.5rem 0 6.5rem;
      }
      .hero-eyebrow {
        font-family: var(--ape-font-mono);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        color: var(--ape-amber-dim);
        margin: 0 0 2.25rem;
      }
      .hero-title {
        font-family: var(--ape-font-display);
        font-weight: 400;
        font-size: clamp(3.25rem, 8.5vw, 6.5rem);
        line-height: 0.98;
        letter-spacing: -0.018em;
        margin: 0 0 2.25rem;
        color: var(--ape-text);
      }
      .hero-title .accent {
        color: var(--ape-amber);
        font-style: italic;
      }
      .hero-sub {
        font-family: var(--ape-font-prose);
        font-size: 1.18rem;
        line-height: 1.55;
        color: var(--ape-text-muted);
        max-width: 38rem;
        margin: 0 0 2.75rem;
      }

      .cta-row { display: flex; gap: 1rem; flex-wrap: wrap; }
      .cta {
        font-family: var(--ape-font-mono);
        font-size: 0.9rem;
        letter-spacing: 0.04em;
        padding: 0.85rem 1.35rem;
        border-radius: 4px;
        transition: background 0.18s ease, border-color 0.18s ease, color 0.18s ease;
      }
      .cta.primary {
        background: var(--ape-amber);
        color: var(--ape-bg);
        border: 1px solid var(--ape-amber);
      }
      .cta.primary:hover {
        background: var(--ape-amber-bright);
        border-color: var(--ape-amber-bright);
        color: var(--ape-bg);
      }
      .cta.ghost {
        background: transparent;
        color: var(--ape-text);
        border: 1px solid var(--ape-border-strong);
      }
      .cta.ghost:hover {
        border-color: var(--ape-amber);
        color: var(--ape-amber);
      }

      /* ────────────────  §I — The shape (editorial lede + drop cap)  ──────────────── */

      .essay { max-width: 44rem; }

      .lede {
        font-family: var(--ape-font-display);
        font-weight: 400;
        font-size: clamp(1.4rem, 2.1vw, 1.75rem);
        line-height: 1.45;
        letter-spacing: -0.005em;
        color: var(--ape-text);
        margin: 0 0 2rem;
      }
      .lede strong {
        font-weight: 400;
        color: var(--ape-amber);
      }
      .lede em {
        font-style: italic;
        color: var(--ape-text);
      }
      .dropcap {
        float: left;
        font-family: var(--ape-font-display);
        font-style: normal;
        font-size: 4.6em;
        line-height: 0.85;
        padding: 0.08em 0.12em 0 0;
        margin: 0.05em 0.05em 0 0;
        color: var(--ape-amber);
      }

      .aside {
        margin: 2.25rem 0 0;
        font-family: var(--ape-font-display);
        font-style: italic;
        font-size: 1.05rem;
        line-height: 1.55;
        color: var(--ape-text-muted);
      }
      .aside a {
        color: var(--ape-text-muted);
        border-bottom: 1px solid var(--ape-border-strong);
        transition: color 0.18s ease, border-color 0.18s ease;
      }
      .aside a:hover {
        color: var(--ape-amber);
        border-bottom-color: var(--ape-amber);
      }

      /* ────────────────  §II — Translation (hero pair + cards)  ──────────────── */

      .big-translation {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        align-items: stretch;
        margin: 0 0 4rem;
        padding: 2.25rem 0 2.5rem;
        border-top: 1px solid var(--ape-border);
        border-bottom: 1px solid var(--ape-border);
      }
      @media (min-width: 860px) {
        .big-translation {
          grid-template-columns: 1fr auto 1fr;
          gap: 2.5rem;
        }
      }
      .big-side {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
      }
      .side-tag {
        font-family: var(--ape-font-mono);
        font-size: 0.66rem;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        color: var(--ape-text-faint);
        margin: 0;
      }
      .big-prose .side-text {
        font-family: var(--ape-font-display);
        font-size: clamp(1.25rem, 1.7vw, 1.45rem);
        line-height: 1.5;
        color: var(--ape-text);
        margin: 0;
      }
      .big-glyph .side-text.mono {
        font-family: var(--ape-font-mono);
        font-weight: 400;
        font-size: clamp(0.95rem, 1.15vw, 1.05rem);
        line-height: 1.7;
        color: var(--ape-amber);
        white-space: pre-wrap;
        overflow-wrap: anywhere;
        margin: 0;
        padding: 0;
        background: transparent;
        display: block;
      }
      .big-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--ape-amber-dim);
      }
      @media (max-width: 859px) {
        .big-divider { padding: 0.5rem 0; }
      }
      .big-arrow {
        font-family: var(--ape-font-mono);
        font-size: 1.6rem;
        line-height: 1;
        color: var(--ape-amber);
        opacity: 0.7;
      }

      .translation-blurb {
        max-width: 52rem;
        font-family: var(--ape-font-prose);
        font-size: 1rem;
        line-height: 1.65;
        color: var(--ape-text-muted);
        margin: 0 0 3rem;
      }
      .translation-blurb code {
        font-family: var(--ape-font-mono);
        color: var(--ape-amber);
        background: rgba(212, 161, 74, 0.08);
        padding: 0.05em 0.3em;
        border-radius: 3px;
        font-size: 0.95em;
      }
      :root[data-theme='light'] .translation-blurb code {
        background: rgba(154, 77, 12, 0.08);
      }
      .translation-more {
        font-family: var(--ape-font-display);
        font-style: italic;
        font-size: 1.05rem;
        color: var(--ape-text-muted);
        margin: 0 0 1.75rem;
      }

      .cards {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.25rem;
      }
      @media (min-width: 900px) {
        .cards { grid-template-columns: repeat(3, 1fr); }
      }

      /* ────────────────  §III — Why it matters  ──────────────── */

      .why { max-width: 46rem; }
      .statements {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 2.25rem;
      }
      .statement {
        display: grid;
        grid-template-columns: 2.5rem 1fr;
        gap: 1.4rem;
        align-items: baseline;
        opacity: 0;
        transform: translateY(14px);
        transition:
          opacity 700ms cubic-bezier(.2,.8,.2,1),
          transform 700ms cubic-bezier(.2,.8,.2,1);
        transition-delay: calc(var(--i) * 95ms);
      }
      .statement.visible {
        opacity: 1;
        transform: translateY(0);
      }
      .statement .marker {
        font-family: var(--ape-font-mono);
        font-size: 0.68rem;
        letter-spacing: 0.18em;
        color: var(--ape-amber-dim);
        padding-top: 0.5rem;
      }
      .statement p {
        margin: 0;
        font-family: var(--ape-font-display);
        font-weight: 400;
        font-size: clamp(1.4rem, 2.1vw, 1.85rem);
        line-height: 1.32;
        letter-spacing: -0.005em;
        color: var(--ape-text);
      }
      .statement .key {
        font-style: normal;
        color: var(--ape-amber);
        margin-right: 0.35rem;
      }
      .statement em { font-style: italic; }

      /* ────────────────  §IV — Ship manifest  ──────────────── */

      .terminal-head {
        font-family: var(--ape-font-mono);
        font-weight: 400;
        font-size: 0.95rem;
        letter-spacing: 0.01em;
        color: var(--ape-text);
        margin: 0 0 2.5rem;
        display: inline-flex;
        align-items: baseline;
      }
      .terminal-head .prompt { color: var(--ape-amber); }
      .terminal-head .sp { white-space: pre; }
      .terminal-head .cmd { color: var(--ape-text); }
      .terminal-head .flag { color: var(--ape-amber); }
      .terminal-head .caret {
        color: var(--ape-amber);
        margin-left: 0.25ch;
        animation: ape-blink 1.1s step-end infinite;
      }
      @keyframes ape-blink {
        0%, 50%  { opacity: 1; }
        51%, 100% { opacity: 0; }
      }

      .manifest {
        margin: 0;
        padding: 0.5rem 0 0.5rem 1.5rem;
        border-left: 1px solid var(--ape-border);
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
      }
      .manifest .row {
        display: grid;
        grid-template-columns: 20ch 1fr;
        column-gap: 1.75rem;
        align-items: baseline;
        font-family: var(--ape-font-mono);
        font-size: 0.92rem;
        line-height: 1.6;
        opacity: 0;
        transform: translateX(-8px);
        transition:
          opacity 500ms ease-out,
          transform 500ms ease-out;
        transition-delay: calc(var(--i) * 60ms);
      }
      .manifest .row.visible {
        opacity: 1;
        transform: translateX(0);
      }
      .manifest dt {
        color: var(--ape-amber);
        font-weight: 400;
        letter-spacing: 0.01em;
      }
      .manifest dd {
        margin: 0;
        color: var(--ape-text-muted);
      }
      .manifest .value { color: var(--ape-amber-bright); }

      @media (max-width: 720px) {
        .manifest { padding-left: 1rem; }
        .manifest .row {
          grid-template-columns: 1fr;
          column-gap: 0;
          row-gap: 0.1rem;
        }
        .manifest dt { padding-bottom: 0.1rem; }
      }

      /* ────────────────  Reveal animation (essay)  ──────────────── */

      .essay,
      .big-translation {
        opacity: 0;
        transform: translateY(10px);
        transition:
          opacity 700ms cubic-bezier(.2,.8,.2,1),
          transform 700ms cubic-bezier(.2,.8,.2,1);
      }
      .essay.visible,
      .big-translation.visible {
        opacity: 1;
        transform: translateY(0);
      }

      @media (prefers-reduced-motion: reduce) {
        .statement, .manifest .row, .essay, .big-translation {
          opacity: 1;
          transform: none;
          transition: none;
        }
        .terminal-head .caret { animation: none; }
      }

      /* ────────────────  Footer  ──────────────── */

      .site-footer {
        position: relative;
        z-index: 1;
        border-top: 1px solid var(--ape-border);
        margin-top: 4rem;
        padding: 4rem clamp(1.25rem, 5vw, 3rem) 2.5rem;
        max-width: 70rem;
        margin-left: auto;
        margin-right: auto;
        width: 100%;
        box-sizing: border-box;
      }
      .footer-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2.5rem;
      }
      @media (min-width: 760px) {
        .footer-grid {
          grid-template-columns: 1.4fr repeat(3, 1fr);
          gap: 2rem;
        }
      }
      .footer-brand .footer-mark {
        font-family: var(--ape-font-mono);
        font-weight: 500;
        font-size: 1rem;
        color: var(--ape-text);
        letter-spacing: 0.03em;
        margin: 0 0 0.75rem;
      }
      .footer-brand .mark-arrow { color: var(--ape-amber); }
      .footer-tagline {
        font-family: var(--ape-font-display);
        font-style: italic;
        font-size: 1.05rem;
        line-height: 1.5;
        color: var(--ape-text-muted);
        margin: 0 0 0.85rem;
      }
      .footer-stack {
        font-family: var(--ape-font-mono);
        font-size: 0.78rem;
        letter-spacing: 0.05em;
        color: var(--ape-text-faint);
        margin: 0;
      }
      .footer-head {
        font-family: var(--ape-font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        color: var(--ape-amber-dim);
        margin: 0 0 1rem;
      }
      .footer-col ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
      }
      .footer-col a {
        font-family: var(--ape-font-prose);
        font-size: 0.92rem;
        color: var(--ape-text-muted);
        transition: color 0.18s ease;
      }
      .footer-col a:hover { color: var(--ape-amber); }

      .footer-rule {
        height: 1px;
        background: var(--ape-border);
        margin: 3rem 0 1.5rem;
      }
      .footer-copy {
        font-family: var(--ape-font-display);
        font-style: italic;
        font-size: 0.92rem;
        line-height: 1.5;
        color: var(--ape-text-faint);
        margin: 0;
      }
    </style>

    <script is:inline>
      (() => {
        const items = document.querySelectorAll('[data-reveal]');
        if (!items.length) return;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) {
          items.forEach(el => el.classList.add('visible'));
          return;
        }
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              io.unobserve(e.target);
            }
          }
        }, { threshold: 0.18, rootMargin: '0px 0px -40px 0px' });
        items.forEach(el => io.observe(el));
      })();
    </script>
  </body>
</html>
